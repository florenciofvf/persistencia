package br.com.teste;

defun main(valor) {
	return filtrar([1, 2, -3, 4, 50, 6], defun lamb(e){return e >= valor;});
}

defun filtrar(lista, f) {
	if(lista == []) {
		return [];
	}

	if(f(${lista:head})) {
		return ${lista:head} .. filtrar(${lista:tail}, f);
	} else {
		return filtrar(${lista:tail}, f);
	}
}