defun quickSort(lista) {
	if(lista == []) {
		return [];
	} else {
		return quickSort(lt(${lista:head}, ${lista:tail})) .. ${lista:head} .. quickSort(ge(${lista:head}, ${lista:tail}));
	}
}

defun lt(valor, lista) {
	if(lista == []) {
		return [];
	}

	if(${lista:head} < valor) {
		return ${lista:head} .. lt(valor, ${lista:tail});
	} else {
		return lt(valor, ${lista:tail});
	}
}

defun ge(valor, lista) {
	if(lista == []) {
		return [];
	}

	if(${lista:head} >= valor) {
		return ${lista:head} .. ge(valor, ${lista:tail});
	} else {
		return ge(valor, ${lista:tail});
	}
}
