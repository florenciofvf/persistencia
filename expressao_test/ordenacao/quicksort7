package br.com.teste;

defun main() {
	return quickSort([46, 1, 2, -3, 4, 50, 6, 0, 55]);
}

defun quickSort(lista) {
	if(lista == []) {
		return [];
	}

	local menores = lt(${lista:head}, ${lista:tail});
	local maiores = ge(${lista:head}, ${lista:tail});

	return quickSort(menores) .. ${lista:head} .. quickSort(maiores);
}

defun lt(valor, lista) {
	if(lista == []) {
		return [];
	}

	if(${lista:head} < valor) {
		return ${lista:head} .. lt(valor, ${lista:tail});
	} else {
		return lt(valor, ${lista:tail});
	}
}

defun ge(valor, lista) {
	if(lista == []) {
		return [];
	}

	if(${lista:head} >= valor) {
		return ${lista:head} .. ge(valor, ${lista:tail});
	} else {
		return ge(valor, ${lista:tail});
	}
}